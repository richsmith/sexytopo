<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/panelBackground</item>
        <item name="background">@color/lightBackground</item>

        <!-- SexyTopo branded colors -->
        <item name="colorPrimary">@color/sexyTopoDarkGreen</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/sexyTopoDarkGreen</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/sexyTopoDarkGreen</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/sexyTopoDarkGreen</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
        <item name="colorTertiary">@color/sexyTopoDarkGreen</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/sexyTopoDarkGreen</item>
        <item name="colorOnTertiaryContainer">@color/white</item>

        <!-- Surface colors for menus and popups in dark mode -->
        <item name="colorSurface">@color/dialogSurface</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/dialogSurface</item>

        <!-- FAB styling -->
        <item name="floatingActionButtonStyle">@style/Widget.App.FloatingActionButton</item>


        <!-- Material dialog styling -->
        <item name="materialAlertDialogTheme">@style/MaterialAlertDialog.App</item>
    </style>

    <style name="MaterialAlertDialog.App" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/DialogCorners</item>
    </style>

    <style name="DialogCorners">
        <item name="cornerSize">16dp</item>
    </style>

</resources>
