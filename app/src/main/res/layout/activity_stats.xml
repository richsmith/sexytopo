<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="org.hwyl.sexytopo.control.activity.StatsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/panelBackground">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/panelBackground"
            app:title="@string/title_activity_survey"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/lightBackground"
            android:padding="16dp">

            <!-- Current Survey Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_title_this_survey"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:paddingBottom="12dp" />

                    <!-- Length -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_length" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLength" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Vertical Range -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_vertical_range" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldDepth" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Number of Stations -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_number_stations" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldNumberStations" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Number of Legs -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_number_legs" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldNumberLegs" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Number of Splays -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_number_splays" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldNumberSplays" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Longest Leg -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_longest_leg" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLongestLeg" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Shortest Leg -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_shortest_leg" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldShortestLeg" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Linked Surveys Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsAllLinkedSurveys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_title_linked_surveys"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:paddingBottom="12dp" />

                    <!-- Number of Surveys -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_number_linked_surveys" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldNumberLinkedSurveys" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Length -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_length" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLinkedLength" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Vertical Range (hidden) -->
                    <LinearLayout
                        style="@style/StatsRow"
                        android:visibility="gone">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_vertical_range" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLinkedDepth" />
                    </LinearLayout>

                    <!-- Number of Stations -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_number_stations" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLinkedNumberStations" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Number of Legs -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_number_legs" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLinkedNumberLegs" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Number of Splays -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_number_splays" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLinkedNumberSplays" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Longest Leg -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_longest_leg" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLinkedLongestLeg" />
                    </LinearLayout>

                    <View style="@style/StatsDivider" />

                    <!-- Shortest Leg -->
                    <LinearLayout style="@style/StatsRow">
                        <TextView
                            style="@style/StatsLabel"
                            android:text="@string/stats_shortest_leg" />
                        <TextView
                            style="@style/StatsValue"
                            android:id="@+id/statsFieldLinkedShortestLeg" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
